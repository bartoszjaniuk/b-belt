{
  "name": "@i3artosh/b-belt",
  "version": "0.0.1",
  "description": "utility package with axios interceptors",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "axios": "*"
  },
  "dependencies": {
    "change-case": "5.4.4"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/github": "10.0.5",
    "@semantic-release/npm": "12.0.1",
    "@semantic-release/release-notes-generator": "13.0.0",
    "@commitlint/cli": "19.6.1",
    "@commitlint/config-conventional": "19.6.0",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "@typescript-eslint/parser": "8.18.0",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "husky": "9.1.7",
    "prettier": "3.4.2",
    "tsup": "8.3.5",
    "typescript": "5.7.2",
    "typescript-eslint": "8.57.0",
    "semantic-release": "24.2.0",
    "vitest": "2.1.8"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsup",
    "lint": "eslint \"src/**/*.ts\" \"__tests__/**/*.ts\" --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\" --no-error-on-unmatched-pattern",
    "format:check": "prettier --check \"src/**/*.ts\" \"__tests__/**/*.ts\" --no-error-on-unmatched-pattern",
    "type-check": "tsc --pretty --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bartoszjaniuk/b-belt.git"
  },
  "author": "Bartosz",
  "bugs": {
    "url": "https://github.com/bartoszjaniuk/b-belt/issues"
  },
  "homepage": "https://github.com/bartoszjaniuk/b-belt#readme",
  "publishConfig": {
    "access": "public"
  }
}
